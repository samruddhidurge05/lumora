# Firebase configuration
FIREBASE_PROJECT_ID=your-firebase-project-id

# SQLite or PostgreSQL database URL
DATABASE_URL=sqlite:///./lumora.db

# Cryptographic token signing secret (must be at least 16 characters in dev, 32+ in prod)
JWT_SECRET_KEY=generate-a-strong-random-key-at-least-32-chars

# PAYMENT_GATEWAY can be: "mock" | "razorpay"
PAYMENT_GATEWAY=mock
PAYMENT_CURRENCY=INR

# Razorpay credentials (required if PAYMENT_GATEWAY=razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Optional Cloudflare R2 storage credentials
# STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_ENDPOINT=your_r2_endpoint
R2_BUCKET_NAME=your_r2_bucket_name

# Base URL for static/file downloads
PUBLIC_BASE_URL=http://localhost:8000
