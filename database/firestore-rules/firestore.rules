rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasRole(role) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isVendorOrAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // ── Platform settings — public read (needed for maintenance banner), admin write ──
    match /platformSettings/{docId} {
      allow read: if true;       // platform status must be readable by guests too
      allow write: if isAdmin();
    }

    // ── Users — own profile read/write, admin can read all ──────────────────
    match /users/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
      // Allow querying users collection (for vendor/affiliate lists in admin)
      allow list:  if isAdmin();
    }

    // ── Vendors collection — own record or admin ─────────────────────────────
    match /vendors/{vendorId} {
      allow read:  if isOwner(vendorId) || isAdmin();
      allow write: if isOwner(vendorId) || isAdmin();
      allow list:  if isAdmin();
    }

    // ── Affiliates collection — own record or admin ──────────────────────────
    match /affiliates/{affiliateId} {
      allow read:  if isOwner(affiliateId) || isAdmin();
      allow write: if isOwner(affiliateId) || isAdmin();
      allow list:  if isAdmin();
    }

    // ── Customers collection — own record or admin ───────────────────────────
    match /customers/{customerId} {
      allow read:  if isOwner(customerId) || isAdmin();
      allow write: if isOwner(customerId) || isAdmin();
      allow list:  if isAdmin();
    }

    // ── Products — public read, vendor/admin write ───────────────────────────
    match /products/{productId} {
      allow read:  if true;    // Public marketplace read
      allow create: if isVendorOrAdmin();
      allow update: if isVendorOrAdmin();
      allow delete: if isAdmin();
    }

    // ── Orders — buyer or vendor who owns a line item, or admin ─────────────
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.buyerId ||
        request.auth.uid == resource.data.vendorId ||
        isAdmin()
      );
      allow write: if isSignedIn() && (
        request.auth.uid == request.resource.data.buyerId ||
        request.auth.uid == request.resource.data.vendorId ||
        isAdmin()
      );
      // NOTE: Firestore cannot filter list results server-side, so a broad
      // `allow list: if isSignedIn()` exposes the existence of every order
      // (document metadata leaks even before field-level read).
      // Restrict list to admin only. Frontend queries for buyer/vendor orders
      // must use `get` on individual documents or a collection group query
      // constrained by buyerId/vendorId — both of which are covered by the
      // read rule above.
      allow list: if isAdmin();
    }

    // ── Purchases — buyer or admin ───────────────────────────────────────────
    match /purchases/{purchaseId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Downloads — buyer or admin ────────────────────────────────────────────
    match /downloads/{downloadId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Reviews — public read, authenticated write (for review authors) ──────
    match /reviews/{reviewId} {
      allow read:  if true;
      allow write: if isSignedIn();
    }

    // ── Vendor stats — vendor or admin ────────────────────────────────────────
    match /vendorStats/{vendorId} {
      allow read:  if isOwner(vendorId) || isAdmin();
      allow write: if isAdmin();    // only backend admin SDK writes these
    }

    // ── Vendor notifications — vendor or admin ────────────────────────────────
    match /vendorNotifications/{notifId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Affiliate conversions — affiliate or admin ────────────────────────────
    match /affiliateConversions/{convId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Auth logs — append-only by authenticated users ────────────────────────
    // logAuthEvent is only called when a Firebase user is signed in.
    // Admin mock sessions skip logAuthEvent (no Firebase session active).
    match /auth_logs/{logId} {
      allow create: if isSignedIn();
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // ── Reports — admin read/write, authenticated users can create ──────────────
    match /reports/{reportId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
      allow create: if isSignedIn();   // customers can submit reports
      allow list:   if isAdmin();
    }

    // ── Admin-only collections ─────────────────────────────────────────────────
    match /adminReferralLinks/{docId} {
      allow read, write: if isAdmin();
    }

    match /adminAnalytics/{docId} {
      allow read, write: if isAdmin();
    }

    match /adminPromotions/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Affiliate orders ledger — admin read/write ───────────────────────────
    match /adminAffiliateOrders/{orderId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
      allow list:  if isAdmin();
    }

    // ── Admin team and notifications ──────────────────────────────────────────
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    // ── Cart — own cart only ──────────────────────────────────────────────────
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Wishlist — own wishlist only ─────────────────────────────────────────
    match /wishlists/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Notifications — own only ──────────────────────────────────────────────
    match /notifications/{userId}/{notifId} {
      allow read, write: if isOwner(userId);
    }

    // ── Conversations & Messages — buyer, seller or admin ──────────────────────
    match /conversations/{conversationId} {
      allow read, write: if isSignedIn() && (
        request.auth.uid == resource.data.buyer_id ||
        request.auth.uid == resource.data.seller_id ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        request.auth.uid == request.resource.data.buyer_id ||
        request.auth.uid == request.resource.data.seller_id ||
        isAdmin()
      );
      allow list: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.buyer_id ||
          request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.seller_id ||
          isAdmin()
        );
      }
    }

    // ── Deny everything else by default ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
